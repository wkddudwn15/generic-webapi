# このファイルは設定例です。
# コピーして .env.local を作成し、実際のAPI Keyを記入してください。
#
#   cp .env.example .env.local
#
# server.js は .env.local を読み込みます。
# .env.local は Git にコミットしないでください（.gitignore 済み）。

# OpenAI を使う場合（デフォルト）
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.5

# Google Gemini を使う場合
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-3.5-flash

# 利用するプロバイダ（openai または gemini）
PROVIDER=openai

# Render などで一時的に原因を画面へ出したい場合だけ true にする
SHOW_ERROR_DETAILS=false

# サーバーのポート（省略可、デフォルトは 8080）
PORT=8080
